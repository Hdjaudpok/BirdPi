# === BirdPi Configuration ===
# Copy this file to config.env and fill in your values.
# See docs/installation.md for setup instructions.

# --- YouTube Live Streaming (optional) ---
STREAM_KEY=your_youtube_stream_key_here
RTMP_URL=rtmp://a.rtmp.youtube.com/live2/$STREAM_KEY
CAM_FPS=10
CAM_BITRATE=400000

# --- Telegram Alerts (required) ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# --- Motion Detection ---
MOTION_STREAM_PORT=8081
MOTION_DEBOUNCE_SEC=30
NO_MOTION_STOP_SEC=180

# --- Battery Monitor (optional, requires ADC hardware) ---
LOW_BATTERY_VOLTAGE=3.30
BATTERY_CHECK_INTERVAL_SEC=120

# --- Telegram Alert Settings ---
TELEGRAM_START_ALERT=1
TELEGRAM_START_MESSAGE="Motion detected in birdhouse"
TELEGRAM_REALTIME_MODE=1
TELEGRAM_INTERVAL_SEC=5
TELEGRAM_MAX_PER_EVENT=10
TELEGRAM_EVENT_MESSAGE="Motion ongoing in birdhouse"
TELEGRAM_SNAPSHOT_COUNT=4
TELEGRAM_SNAPSHOT_INTERVAL_SEC=0.35
TELEGRAM_MIN_JPEG_SIZE=5000

# --- AI Detection (YOLOv8-nano) ---
TELEGRAM_AI_ENABLED=1
TELEGRAM_AI_REQUIRE_TARGET=1
TELEGRAM_AI_TARGETS=bird
TELEGRAM_AI_CONFIDENCE=0.35
TELEGRAM_AI_NMS=0.45
TELEGRAM_AI_INPUT_SIZE=224
TELEGRAM_AI_ANNOTATE=1
TELEGRAM_AI_MODEL=$HOME/birdpi/models/yolov8n_birdpi_224.onnx

# --- CLAHE (IR/night vision enhancement) ---
TELEGRAM_CLAHE_ENABLED=1
TELEGRAM_CLAHE_CLIP=2.0

# --- Temporal Tracker (multi-frame confirmation) ---
TELEGRAM_TRACKER_ENABLED=1
TELEGRAM_TRACKER_CONFIRM_FRAMES=3

# --- Activity Classifier ---
TELEGRAM_CLASSIFIER_ENABLED=1
